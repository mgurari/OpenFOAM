FoamFile
{
    format      ascii;
    class       volScalarField;
    location    "0";
    object      omega;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 -1 0 0 0 0];

internalField   uniform 8;

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           uniform 8;
    }
    outlet
    {
        type            inletOutlet;
        inletValue      uniform 8;
        value           uniform 8;
    }
    bottom
    {
        type            inletOutlet;
        inletValue      uniform 8;
        value           uniform 8;
    }
    top
    {
        type            inletOutlet;
        inletValue      uniform 8;
        value           uniform 8;
    }
    right
    {
        type            inletOutlet;
        inletValue      uniform 8;
        value           uniform 8;
    }
    left
    {
        type            inletOutlet;
        inletValue      uniform 8;
        value           uniform 8;
    }
    body
    {
        type            omegaWallFunction;
        value           uniform 8;
    }
}



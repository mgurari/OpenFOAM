FoamFile
{
    format      ascii;
    class       volVectorField;
    location    "0";
    object      U;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 1 -1 0 0 0 0];

flowSpeed (9.74 0 2.25);
internalField uniform $flowSpeed;

boundaryField
{
    inlet
    {
        type            freestreamVelocity;
        freestreamValue uniform $flowSpeed;
        value           uniform $flowSpeed;
    }
    outlet
    {
        type            freestreamVelocity;
        freestreamValue uniform $flowSpeed;
        value           uniform $flowSpeed;
    }
    bottom
    {
        type            freestreamVelocity;
        freestreamValue uniform $flowSpeed;
        value           uniform $flowSpeed;
    }
    top
    {
        type            freestreamVelocity;
        freestreamValue uniform $flowSpeed;
        value           uniform $flowSpeed;
    }
    right
    {
        type            freestreamVelocity;
        freestreamValue uniform $flowSpeed;
        value           uniform $flowSpeed;
    }
    left
    {
        type            freestreamVelocity;
        freestreamValue uniform $flowSpeed;
        value           uniform $flowSpeed;
    }
    body
    {
        type            noSlip;
    }
}



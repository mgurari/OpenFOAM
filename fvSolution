FoamFile
{
	format ascii;
	class dictionary;
	object fvSolution;
}

solvers
{
	p
	{
		solver PCG;
		preconditioner FDIC;
		tolerance 1e-5;
		relTol 0.01;
	}

	pFinal
	{
		$p;
		relTol 0;
	}

	Phi
	{
		$p;
	}

	"(U|k|omega|epsilon)"
	{
		solver PBiCGStab;
		preconditioner DILU;
		tolerance 1e-5;
		relTol 0.01;
	}

	"(U|k|omega|epsilon)Final"
	{
		$U;
		relTol 0;
	}
}

SIMPLE
{
	residualControl
	{
		p 1e-7;
		U 1e-7;
		"(k|omega|epsilon)" 1e-7;
	}

	nNonOrthogonalCorrectors 0;
	pRefCell 0;
	pRefValue 0;
}

PIMPLE
{
	residualControl
	{
		p 1e-7;
		U 1e-7;
		"(k|omega|epsilon)" 1e-7;
	}

	transonic no;
	nCorrectors 3;
	nNonOrthogonalCorrectors 0;
	nOuterCorrectors 3;
	momentumPredictor yes;
}

potentialFlow
{
	nNonOrthogonalCorrectors 10;
}

relaxationFactors
{
	fields
	{
		p 0.5;
	}
	
	equations
	{
		U 0.7;
		"(k|omega|epsilon)" 0.7;
	}
}

FoamFile
{
	format ascii;
	class dictionary;
	object snappyHexMeshDict;
}

castellatedMesh true;
snap true;
addLayers true;
mergeTolerance 1e-6;
debug 0;

geometry
{
	body
	{
		type triSurfaceMesh;
		file "capstone.stl";
	}

	cylinder
	{
		type searchableCylinder;
		point1 (0.6 0.947 0.16);
		point2 (1.6 0.947 0.16);
		radius 0.06;
	}
};

castellatedMeshControls
{
	locationInMesh (-5 -3 1.1);
	maxLocalCells 800000;
	maxGlobalCells 10000000;
	minRefinementCells 6;
	maxLoadUnbalance 0.5;
	nCellsBetweenLevels 3;
	resolveFeatureAngle 40;
	allowFreeStandingZoneFaces false;

	refinementSurfaces
	{
		body
		{
			level (6 6);
		}
	}

	refinementRegions
	{
		cylinder
		{
			mode distance;
			levels ((0.07 4));
		}
	}

	features
	(
		{
			file "capstone.eMesh";
			level 0;
		}
	);
} 

